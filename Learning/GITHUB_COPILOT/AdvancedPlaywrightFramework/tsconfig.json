{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./dist",
        "rootDir": "./tests",
        "baseUrl": ".",
        "paths": {
            "@pages/*": [
                "tests/pages/*"
            ],
            "@fixtures/*": [
                "tests/fixtures/*"
            ],
            "@utils/*": [
                "tests/utils/*"
            ]
        }
    },
    "include": [
        "tests/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "playwright-report",
        "test-results"
    ]
}