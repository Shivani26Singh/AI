{
    "name": "advanced-playwright-framework",
    "version": "1.0.0",
    "description": "Advanced Playwright E2E testing framework with Page Object Model, fixtures, and best practices",
    "scripts": {
        "test": "playwright test",
        "test:headed": "playwright test --headed",
        "test:ui": "playwright test --ui",
        "test:debug": "playwright test --debug",
        "test:chrome": "playwright test --project=chromium",
        "test:firefox": "playwright test --project=firefox",
        "test:webkit": "playwright test --project=webkit",
        "test:mobile": "playwright test --project=mobile-chrome",
        "test:smoke": "playwright test --grep @smoke",
        "test:critical": "playwright test --grep @critical",
        "codegen": "playwright codegen",
        "report": "playwright show-report",
        "trace": "playwright show-trace",
        "lint": "eslint tests/ --ext .ts",
        "format": "prettier --write 'tests/**/*.ts'"
    },
    "devDependencies": {
        "@playwright/test": "^1.45.0",
        "@types/node": "^20.14.0",
        "typescript": "^5.5.0",
        "eslint": "^8.57.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "prettier": "^3.3.0",
        "dotenv": "^16.4.0",
        "@faker-js/faker": "^8.4.0"
    }
}